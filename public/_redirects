# Astro generates static HTML for each route - no SPA fallback needed

# Strip trailing slashes (canonical URLs have no trailing slash; avoids 301 chains)
/*/    /:splat    301

# Specific redirects for SEO
/about           /#about       301
/services        /#services    301
/contact         /#contact-form 301

# Handle common requests
/robots.txt      /robots.txt   200
/sitemap.xml     /sitemap.xml  200
/favicon.ico     /favicon.ico  200
