---
import BaseLayout from '../layouts/BaseLayout.astro';
import LocationLanding from '../components/LocationLanding';
import { getLocationBySlug } from '../data/locations';

const baseUrl = 'https://mapletreegardenservices.com';
const location = getLocationBySlug('prestwick')!;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": baseUrl },
    { "@type": "ListItem", "position": 2, "name": "Locations", "item": `${baseUrl}/locations` },
    { "@type": "ListItem", "position": 3, "name": `Garden Services ${location.name}`, "item": `${baseUrl}/${location.slug}` }
  ]
};

const placeSchema = {
  "@context": "https://schema.org",
  "@type": "Place",
  "name": `Garden Services in ${location.name}, Ayrshire`,
  "description": location.description,
  "url": `${baseUrl}/${location.slug}`,
  "address": { "@type": "PostalAddress", "addressLocality": location.name, "addressRegion": "Ayrshire", "addressCountry": "GB" },
  "geo": { "@type": "GeoCoordinates", "latitude": location.geo.latitude, "longitude": location.geo.longitude },
  "areaServed": location.areaServed
};
---

<BaseLayout
  title={location.title}
  description={location.description}
  canonical={`${baseUrl}/${location.slug}`}
  image={`${baseUrl}/maple-leaf.svg`}
  additionalSchema={[breadcrumbSchema, placeSchema]}
>
  <LocationLanding location={location} client:load />
</BaseLayout>
