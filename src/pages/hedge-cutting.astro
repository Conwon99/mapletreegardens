---
import BaseLayout from '../layouts/BaseLayout.astro';
import HedgeCutting from '../components/pages/HedgeCutting';

const baseUrl = 'https://mapletreegardenservices.com';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": baseUrl },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": `${baseUrl}/services` },
    { "@type": "ListItem", "position": 3, "name": "Hedge Cutting", "item": `${baseUrl}/hedge-cutting` }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Hedge Cutting & Trimming Services Troon & Ayrshire",
  "description": "Professional hedge cutting, shaping, and maintenance in Troon & Ayrshire. Hedge trimming, height reduction, and garden boundary work.",
  "url": `${baseUrl}/hedge-cutting`,
  "areaServed": [{ "@type": "City", "name": "Troon" }, { "@type": "City", "name": "Prestwick" }, { "@type": "AdministrativeArea", "name": "Ayrshire" }],
  "provider": { "@id": `${baseUrl}/#organization` }
};
---

<BaseLayout
  title="Hedge Cutting & Trimming Troon & Ayrshire | Professional Hedge Maintenance"
  description="Professional hedge cutting and trimming in Troon & Ayrshire. Hedge shaping, height reduction, and boundary maintenance. Free quotes. Serving Troon, Prestwick, Ayr and across Ayrshire."
  canonical={`${baseUrl}/hedge-cutting`}
  image={`${baseUrl}/maple-leaf.svg`}
  additionalSchema={[breadcrumbSchema, serviceSchema]}
>
  <HedgeCutting client:load />
</BaseLayout>
