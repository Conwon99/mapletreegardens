---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero';
import TrustBar from '../components/TrustBar';
import AboutUs from '../components/AboutUs';
import ServicesGrid from '../components/ServicesGrid';
import Reviews from '../components/Reviews';
import Gallery from '../components/Gallery';
import FAQ from '../components/FAQ';
import ContactSection from '../components/ContactSection';

const baseUrl = 'https://mapletreegardenservices.com';

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Maple Tree & Gardens",
  "alternateName": "Maple Tree & Gardening Services",
  "url": baseUrl,
  "description": "Tree surgeon and gardener in Troon and Ayrshire. Tree surgery, lawn mowing, hedge cutting, garden maintenance. Free quotes.",
  "publisher": { "@id": `${baseUrl}/#organization` }
};
---

<BaseLayout
  title="Tree Surgeon & Gardener Troon | Tree Surgery, Lawn Care & Garden Services Ayrshire"
  description="Tree surgeon and gardener in Troon since 2004. Tree surgery, lawn mowing, hedge cutting and garden maintenance across Troon, Prestwick, Ayr and Ayrshire. Free quotes. Storm damage and emergency tree removal."
  canonical={baseUrl}
  image={`${baseUrl}/maple-leaf.svg`}
  additionalSchema={websiteSchema}
>
  <main class="min-h-screen overflow-x-hidden w-full">
    <Hero client:load />
    <TrustBar client:load />
    <AboutUs client:load />
    <ServicesGrid client:load />
    <Reviews client:load />
    <Gallery client:load />
    <FAQ client:load />
    <ContactSection client:load />
  </main>
</BaseLayout>
