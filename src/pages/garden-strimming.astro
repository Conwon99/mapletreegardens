---
import BaseLayout from '../layouts/BaseLayout.astro';
import GardenStrimming from '../components/pages/GardenStrimming';

const baseUrl = 'https://mapletreegardenservices.com';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": baseUrl },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": `${baseUrl}/services` },
    { "@type": "ListItem", "position": 3, "name": "Garden Strimming", "item": `${baseUrl}/garden-strimming` }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Garden Strimming & Edging Services Troon & Ayrshire",
  "description": "Professional garden strimming, edging, and precision finishing in Troon & Ayrshire. Pathway edging, work around obstacles, and hard-to-reach areas.",
  "url": `${baseUrl}/garden-strimming`,
  "areaServed": [{ "@type": "City", "name": "Troon" }, { "@type": "City", "name": "Prestwick" }, { "@type": "AdministrativeArea", "name": "Ayrshire" }],
  "provider": { "@id": `${baseUrl}/#organization` }
};
---

<BaseLayout
  title="Garden Strimming & Edging Troon & Ayrshire | Professional Edging & Finishing"
  description="Professional garden strimming and edging in Troon & Ayrshire. Pathway and border edging, work around obstacles, hard-to-reach areas. Free quotes."
  canonical={`${baseUrl}/garden-strimming`}
  image={`${baseUrl}/maple-leaf.svg`}
  additionalSchema={[breadcrumbSchema, serviceSchema]}
>
  <GardenStrimming client:load />
</BaseLayout>
